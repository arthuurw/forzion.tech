# forzion.tech frontend — variáveis de ambiente (exemplo)
# Copie para .env.local e ajuste. NÃO commitar arquivos .env reais.

# URL canônica de produção do site. Usada como metadataBase (SEO/OpenGraph),
# base de canonical/sitemap/robots. SEMPRE o domínio final de produção
# (NÃO homolog) para que canonical/OG resolvam absolutos corretamente.
NEXT_PUBLIC_SITE_URL=https://forzion.tech

# Permite indexação por buscadores. "true" SOMENTE em produção.
# Ausente/qualquer-outro-valor => robots.txt bloqueia tudo (noindex total) —
# default seguro p/ evitar indexar homolog/staging. Defesa em profundidade
# junto do X-Robots-Tag no nginx do host de homolog.
NEXT_PUBLIC_INDEXABLE=false

# Sentry — amostragem RUM. SEM DSN o SDK é no-op (dev/CI). Os defaults de código
# já são safe (traces 0.05 / replay-session 0.02). Sobrescrever por env só se
# precisar mais sinal num ambiente específico — subir custa egress + CPU.
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_RATE=0.02
# SENTRY_TRACES_SAMPLE_RATE=0.05
