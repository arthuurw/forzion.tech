{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:api": "vitest run --project api",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:property": "vitest run property.test",
    "test:mutation": "stryker run",
    "test:mutation:incremental": "stryker run --incremental",
    "test:contract": "vitest run --config vitest.pact.config.mts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:test": "test-storybook --url http://localhost:6006",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:smoke": "playwright test --grep @smoke --project=chromium-desktop",
    "e2e:security": "playwright test e2e/specs/security",
    "e2e:lgpd": "playwright test e2e/specs/lgpd",
    "e2e:update-snapshots": "playwright test --update-snapshots",
    "e2e:install": "playwright install --with-deps",
    "e2e:sweep": "tsx e2e/scripts/sweep-test-data.ts",
    "analyze": "cross-env ANALYZE=true next build",
    "lhci": "lhci autorun",
    "lhci:auth": "node e2e/scripts/lhci-auth.mjs",
    "lhci:collect": "lhci collect",
    "lhci:assert": "lhci assert",
    "links": "linkinator http://localhost:3000 --recurse --skip \"^https?://(?!localhost)\" --timeout 5000",
    "audit": "npm audit --omit=dev --audit-level=high",
    "audit:dev": "npm audit --audit-level=high",
    "license": "license-checker --production --failOn \"GPL-3.0;AGPL-3.0;LGPL-3.0;CDDL-1.0;EPL-1.0;EPL-2.0\" --summary",
    "sbom": "cyclonedx-npm --ignore-npm-errors --package-lock-only --output-format JSON --output-file sbom.cdx.json",
    "security:all": "npm run audit && npm run license && npm run sbom",
    "knip": "knip",
    "deadcode": "madge --circular --extensions ts,tsx --ts-config tsconfig.json src/",
    "hygiene": "npm run deadcode && npm run knip",
    "openapi:fetch": "node scripts/openapi-fetch.mjs",
    "openapi:gen": "openapi-typescript openapi.json -o src/test/msw/types.ts",
    "openapi:sync": "npm run openapi:fetch && npm run openapi:gen",
    "openapi:check": "npm run openapi:sync && git diff --exit-code src/test/msw/types.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm test",
    "prepare": "cd .. && husky frontend/.husky"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@mui/material-nextjs": "^9.1.1",
    "@mui/x-date-pickers": "^9.7.0",
    "@sentry/nextjs": "^10.61.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "@tanstack/react-query": "^5.101.1",
    "axios": "^1.18.1",
    "dayjs": "^1.11.20",
    "exceljs": "^4.4.0",
    "jose": "^6.2.3",
    "next": "^16.2.9",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "uuid": ">=11.1.1",
    "tmp": "^0.2.7",
    "qs": "^6.15.2",
    "form-data": "^4.0.6",
    "@pact-foundation/pact": {
      "https-proxy-agent": "^7.0.6"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@cyclonedx/cyclonedx-npm": "^5.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@faker-js/faker": "^9.9.0",
    "@fast-check/vitest": "^0.4.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.9",
    "@pact-foundation/pact": "^17.0.0",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/nextjs": "^10.4.6",
    "@storybook/test-runner": "^0.24.4",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/seedrandom": "^3.0.8",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "axe-core": "^4.11.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "knip": "^5.88.1",
    "license-checker": "^25.0.1",
    "linkinator": "^7.6.1",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "openapi-msw": "^2.0.0",
    "openapi-typescript": "^7.13.0",
    "seedrandom": "^3.0.5",
    "storybook": "^10.4.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "vitest-axe": "^1.0.0-pre.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
