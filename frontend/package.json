{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:api": "vitest run --project api",
    "test:watch": "vitest --project unit",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:property": "vitest run property.test",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:test": "test-storybook --url http://localhost:6006",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:smoke": "playwright test --grep @smoke",
    "e2e:security": "playwright test e2e/specs/security",
    "e2e:lgpd": "playwright test e2e/specs/lgpd",
    "e2e:update-snapshots": "playwright test --update-snapshots",
    "e2e:install": "playwright install --with-deps",
    "openapi:fetch": "node scripts/openapi-fetch.mjs",
    "openapi:gen": "openapi-typescript openapi.json -o src/test/msw/types.ts",
    "openapi:sync": "npm run openapi:fetch && npm run openapi:gen",
    "openapi:check": "npm run openapi:sync && git diff --exit-code src/test/msw/types.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm test",
    "prepare": "cd .. && husky frontend/.husky"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/material-nextjs": "^9.0.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.5.0",
    "axios": "^1.16.1",
    "dayjs": "^1.11.20",
    "exceljs": "^4.4.0",
    "jose": "^6.2.3",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/eslintrc": "^3.3.5",
    "@faker-js/faker": "^9.9.0",
    "@fast-check/vitest": "^0.4.1",
    "@mswjs/data": "^0.16.2",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/nextjs": "^10.4.1",
    "@storybook/test-runner": "^0.24.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/seedrandom": "^3.0.8",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "openapi-msw": "^2.0.0",
    "openapi-typescript": "^7.13.0",
    "seedrandom": "^3.0.5",
    "storybook": "^10.4.1",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5",
    "vitest-axe": "^1.0.0-pre.5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
