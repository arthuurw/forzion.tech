# ============================================================
# docker-compose local — copie para .env e preencha
# Gerar JWT_SECRET: openssl rand -base64 64
# ============================================================

# Auth (obrigatório) — COMPARTILHADO backend + frontend.
# Backend assina o JWT (Auth__JwtSecret); o frontend valida a assinatura em
# /api/auth/me com o MESMO segredo. Os dois serviços recebem ${JWT_SECRET} no
# docker-compose, então o valor precisa ser idêntico. Issuer/Audience também
# devem casar com os defaults do backend por ambiente.
JWT_SECRET=sua_chave_secreta_minimo_32_chars
JWT_ISSUER=forzion.tech
JWT_AUDIENCE=forzion.tech

# MFA/2FA (obrigatório — backend falha no startup sem). Chave AES-256 que encripta os
# segredos TOTP em repouso (Mfa__EncryptionKey). Gerar: openssl rand -base64 32 (exatos 32 bytes).
# ESTÁVEL: trocar invalida todos os segredos MFA já cadastrados.
MFA_ENCRYPTION_KEY=

# DataProtection (obrigatório — backend falha no startup sem). Chave AES-256 que cifra as
# chaves de DataProtection persistidas em Postgres (DataProtection__EncryptionKey). Gerar:
# openssl rand -base64 32 (exatos 32 bytes). ESTÁVEL: trocar invalida o keyring persistido.
DATA_PROTECTION_KEY=

# Stripe (obrigatório — backend falha no startup sem SecretKey e WebhookSecret)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_URL_BASE=http://localhost:3000
# STRIPE_TAXA_PLATAFORMA=5
# Stripe__ExpectLivemode=true   # OBRIGATÓRIO em produção — boot falha se sk_live_ e este valor não for true.
#                               # Omitir em Dev/Homolog (default=false → test-mode permitido).

# Seed admin local
SEED_ADMIN_EMAIL=admin@forzion.tech
SEED_ADMIN_PASSWORD=SuaSenhaAdmin123!

# Chave do endpoint interno /internal/processar-renovacoes (cron de cobrança mensal)
# Gerar: openssl rand -hex 32. Mesmo valor deve estar no GitHub secret INTERNAL_API_KEY.
# Vazio = endpoint rejeita todas as requisições (401).
# Production: AUSENTE => app falha no startup (fail-closed). Homolog/Dev: ausente => sobe.
# INTERNAL_API_KEY=

# Pseudonimização do destinatário nos delivery logs (PRIV-02 / LGPD).
# Chave HMAC-SHA256 do e-mail/telefone gravado em email_/whatsapp_delivery_logs.
# Gerar: openssl rand -base64 32  (>= 32 bytes; reusar é o que torna o hash consultável).
# Production: AUSENTE => app falha no startup (fail-closed). Homolog/Dev: ausente => chave
# de dev pública (DeliveryLogSettings.DevDefaultKey) — setar valor real p/ paridade.
# Rotacionar a chave invalida o lookup/erasure por hash das linhas antigas (re-hash não recupera).
# DELIVERY_LOG_HASH_KEY=

# E-mail via Resend (opcional — NullEmailService se vazio)
# RESEND_API_KEY=re_...
# RESEND_WEBHOOK_SECRET=whsec_...  (opcional — webhook de entrega desabilitado se vazio)

# Guardrail de e-mail em não-prod (homolog/dev: EmailSettings.MarcarComoTeste=true via appsettings).
# Resend não tem sandbox → e-mail é real. Estas chaves evitam atingir usuários reais.
# EMAIL_REDIRECT_TO: redireciona TODO destinatário para este inbox de teste.
#   Vazio = SEM redirect (envia ao destinatário real, ainda marcado [HOMOLOG/DEV - TESTE] + banner).
# EMAIL_REDIRECT_TO=qa@forzion.tech
# EMAIL_ALLOWLIST_DOMAINS: CSV de domínios isentos do redirect (passam direto). Vazio = ninguém isento.
# EMAIL_ALLOWLIST_DOMAINS=forzion.tech

# WhatsApp via Meta Cloud API (opcional — NullWhatsAppNotifier se PhoneNumberId/AccessToken vazios)
# Onde pegar: Meta App > WhatsApp > API Setup (PhoneNumberId, token), App > Settings > Basic (AppSecret).
# WHATSAPP_PHONE_NUMBER_ID=<phone-number-id-do-meta>
# WHATSAPP_ACCESS_TOKEN=<token-permanente-do-meta>     # System User token (não o temporário de 24h)
# WHATSAPP_API_VERSION=v21.0
#
# Webhook de status (Meta -> /webhooks/whatsapp). Verify token: string aleatória que você inventa
# e repete na config de webhook do Meta. AppSecret: HMAC SHA256 do payload (X-Hub-Signature-256).
# WHATSAPP_APP_SECRET=<app-secret-do-meta>
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=<string-aleatoria-sua>
#
# Guardrail não-prod (homolog/dev): test number Meta entrega só p/ até 5 números pré-cadastrados.
# MARK_AS_TEST=true (default homolog) liga redirect/allowlist. REDIRECT_TO: 1º alvo recebe tudo.
# ALLOWLIST_PHONES: CSV E.164 isentos do redirect (passam direto). Vazio = ninguém isento.
# WHATSAPP_MARK_AS_TEST=true
# WHATSAPP_REDIRECT_TO=5511999999999
# WHATSAPP_ALLOWLIST_PHONES=5511999999999
