# ============================================================
# docker-compose local — copie para .env e preencha
# Gerar JWT_SECRET: openssl rand -base64 64
# ============================================================

# Auth (obrigatório)
JWT_SECRET=sua_chave_secreta_minimo_32_chars
JWT_ISSUER=forzion.tech
JWT_AUDIENCE=forzion.tech

# Stripe (obrigatório — backend falha no startup sem SecretKey e WebhookSecret)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_URL_BASE=http://localhost:3000
# STRIPE_TAXA_PLATAFORMA=5

# Seed admin local
SEED_ADMIN_EMAIL=admin@forzion.tech
SEED_ADMIN_PASSWORD=SuaSenhaAdmin123!

# Chave do endpoint interno /internal/processar-renovacoes (cron de cobrança mensal)
# Gerar: openssl rand -hex 32. Mesmo valor deve estar no GitHub secret INTERNAL_API_KEY.
# Vazio = endpoint rejeita todas as requisições (401).
# INTERNAL_API_KEY=

# E-mail via Resend (opcional — NullEmailService se vazio)
# RESEND_API_KEY=re_...
# RESEND_WEBHOOK_SECRET=whsec_...  (opcional — webhook de entrega desabilitado se vazio)

# Guardrail de e-mail em não-prod (homolog/dev: EmailSettings.MarcarComoTeste=true via appsettings).
# Resend não tem sandbox → e-mail é real. Estas chaves evitam atingir usuários reais.
# EMAIL_REDIRECT_TO: redireciona TODO destinatário para este inbox de teste.
#   Vazio = SEM redirect (envia ao destinatário real, ainda marcado [HOMOLOG/DEV - TESTE] + banner).
# EMAIL_REDIRECT_TO=qa@forzion.tech
# EMAIL_ALLOWLIST_DOMAINS: CSV de domínios isentos do redirect (passam direto). Vazio = ninguém isento.
# EMAIL_ALLOWLIST_DOMAINS=forzion.tech

# WhatsApp via Meta Cloud API (opcional — NullWhatsAppNotifier se vazio)
# WHATSAPP_PHONE_NUMBER_ID=<phone-number-id-do-meta>
# WHATSAPP_ACCESS_TOKEN=<token-permanente-do-meta>
# WHATSAPP_API_VERSION=v21.0

# CSP Report-Only (build-time, apenas homolog — passa como build ARG no Docker)
# Quando "true", adiciona Content-Security-Policy-Report-Only com a mesma política da CSP enforced.
# Útil para detectar violações sem bloquear. Nunca setar "true" em produção.
# CSP_REPORT_ONLY=true
