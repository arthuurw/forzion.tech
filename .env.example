# docker-compose local — copie para .env e preencha
JWT_SECRET=sua_chave_secreta_minimo_32_chars
JWT_ISSUER=forzion.tech
JWT_AUDIENCE=forzion.tech

# WhatsApp (opcional — deixe vazio para usar NullNotifier)
# WHATSAPP_BASE_URL=https://seu-evolution-api.com
# WHATSAPP_INSTANCE=nome_da_instancia
# WHATSAPP_API_KEY=sua_api_key

# IA — Agentes (Anthropic Claude Haiku-4.5)
# Em dev: configure via User Secrets (dotnet user-secrets set "AI:Internal:ApiKey" "sk-ant-...")
# Em produção: variáveis de ambiente ou secret manager — NUNCA commitar API key
AI__Internal__Model=claude-haiku-4-5-20251001
# AI__Internal__ApiKey=sk-ant-...  ← NÃO descomente aqui, use User Secrets ou env var
AI__TokenBudget__DailyTokensAluno=50000
AI__TokenBudget__DailyTokensTreinador=100000
AI__TokenBudget__MaxToolCallsPerSession=15

# OpenTelemetry (opcional — deixe vazio para desabilitar exportação)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://seu-collector:4317
