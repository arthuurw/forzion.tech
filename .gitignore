# Env files (segredos locais e de server)
.env
.env.*
!.env.example

# Chaves e dumps de banco — NUNCA versionar (repo PÚBLICO).
# age priv decifra TODO backup; dumps têm PII/LGPD. Cobre o restore drill (db-backup.yml).
*.key
*.age
*.dump
*.pem
*.pfx
*.p12

## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml
/.vs

# Artefatos de agente/IA e docs gerados — não versionar.
# docs/api/ é exceção: openapi.v1.json é baseline do gate OpenAPI drift (CI).
/.claude/
/.specs/
/docs/*
!/docs/api/

# Arquivos locais do Visual Studio (preferências por-usuário, não versionar)
*.user

# Artefatos de sessão AI (gerados por skills, não pertencem ao repo)
.security-memory.md
.clean-arch-memory.md
.test-strategy-memory.md
.architecture-memory.md

# Node (deps locais; o app Node vive em frontend/ com seu próprio lock)
node_modules/

# Stryker mutation testing output
stryker-output/
StrykerOutput/
.stryker-tmp/

# Cobertura/coverlet + ReportGenerator (gerados em CI e localmente, não versionar)
coverage/
coverage-report/
coverage-detail/
**/coverage.cobertura.xml
**/coverage.opencover.xml

# Scripts SQL gerados pontualmente (não versionar)
migration_public_schema.sql

# Snapshots do Verify (Fase 6): .received e gerado a cada run; so o .verified e versionado.
*.received.*

# Dumps de crash do MSYS/Git-Bash no Windows (gerados por tooling, nao versionar).
*.stackdump
